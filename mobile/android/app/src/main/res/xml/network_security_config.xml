<?xml version="1.0" encoding="utf-8"?>
<!--
  BeautyAsist ağ güvenliği (hibrit: public HTTPS + yerel/LAN HTTP).

  base-config: cleartext KAPALI → internet üzerindeki canlı backend'e yalnızca HTTPS ile bağlanılır
  (Play güvenlik uyarısını önler, MITM'e kapalı).

  domain-config: cleartext YALNIZCA aşağıdaki yerel/LAN adreslerine izinli.
  Salon içi HTTP sunucusu farklı bir IP/hostname ise, o adresi buraya <domain> olarak EKLEYİN
  (Android network-security-config CIDR/aralık desteklemez; tek tek host girilir).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emülatör → host makinesi -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Yerel geliştirme -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- ÖRNEK salon içi LAN sunucusu — kendi sabit IP'nizle değiştir/çoğaltın -->
        <domain includeSubdomains="true">192.168.1.100</domain>
    </domain-config>
</network-security-config>
