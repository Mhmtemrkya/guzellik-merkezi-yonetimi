# === BeautyAssist Frontend (Next.js) ortam değişkenleri ===

# Tarayıcının backend'e eriştiği yol. Her zaman Next proxy'si üzerinden gider.
# Production'da da /api/proxy kalmalı — backend iç adresi tarayıcıya verilmez.
NEXT_PUBLIC_API_BASE_URL=/api/proxy

# Next proxy'sinin (sunucu tarafı) yönlendireceği gerçek backend API adresi.
BACKEND_API_BASE_URL=http://localhost:5019

# CORS izinli origin listesi (virgülle ayrılır). Credential'lı CORS için '*' KULLANILMAZ;
# yalnızca buradaki origin'ler yansıtılır. (Geriye dönük uyumluluk için CORS_ORIGINS de okunur.)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- PRODUCTION NOTLARI ---
# - BACKEND_API_BASE_URL gerçek backend iç adresi olmalı (örn. http://backend:5019 / https://api-ic.alanadi).
#   Production'da set EDİLMEZSE proxy localhost'a veya WSL gateway'e DÜŞMEZ; "BackendNotConfigured" döner
#   ve hiçbir iç adres response body/header ile sızdırılmaz.
# - CORS_ALLOWED_ORIGINS yalnızca gerçek public domain(ler)inizi içermeli (örn. https://app.beautyassist.com).
# - NEXT_PUBLIC_API_BASE_URL=/api/proxy production'da da değişmemeli.
